# Firebase project config — copy to .env.local and fill with your values
# Never commit .env.local
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Set to 'true' only when running firebase emulators:start locally
# Leave unset (or false) to use production Firebase directly
VITE_USE_EMULATOR=
