rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
      // Everything but groupId is free to update; changing groupId requires the
      // 7-day cooldown (especificaciones.md §2.2) and must stamp groupChangedAt
      // to now in the same write, so the next attempt can be checked against it.
      allow update: if request.auth != null && request.auth.uid == userId
        && (
          request.resource.data.groupId == resource.data.groupId
          || (
            (resource.data.groupChangedAt == null
              || request.time > resource.data.groupChangedAt + duration.value(7, 'd'))
            && request.resource.data.groupChangedAt == request.time
          )
        );
    }

    match /groups/{groupId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.profesorUid == request.auth.uid
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'profesor';
      allow update, delete: if false;
    }

    match /scores/{scoreId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && scoreId.matches(request.auth.uid + '_.*');
    }

    // Mirrors only the fields the spec allows showing about other users
    // (never email or detailed calculations) — read directly by the ranking
    // query, written client-side by the owner (no Cloud Function, requires
    // the paid Blaze plan we're avoiding).
    match /publicProfiles/{uid} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && request.auth.uid == uid;
    }

    // "Último intento" snapshot for the FC review module — overwritten every
    // time a level ends (not just on a new best, unlike scores/).
    match /levelSnapshots/{snapshotId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.uid;
      allow create, update: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && snapshotId.matches(request.auth.uid + '_.*');
    }

    match /sessions/{sessionId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    match /analytics/{eventId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
    }

    match /assessments/{assessmentId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      // Evaluation records are immutable once submitted — no update/delete.
      allow update, delete: if false;
    }

    match /events/{eventId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
    }

    match /leaderboards/{levelId}/entries/{userId} {
      allow read: if request.auth != null;
      allow write: if false; // Cloud Functions only
    }
  }
}
